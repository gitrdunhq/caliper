# syntax=docker/dockerfile:1
# Test image — installs caliper from source with dev deps.
# Unlike the runtime Dockerfile, this always reflects the current checkout.
#
# Build:  bash scripts/build-test.sh           # native host arch (arm64 on Apple Silicon)
#         make test                            # linux/amd64 (CI parity)
# Run:    bash scripts/build-test.sh -- tests/unit/ -q
#
# Arch-agnostic: the FROM and uv pins below are MULTI-ARCH INDEX digests (immutable
# AND per-platform), and jj is selected by the builder's automatic TARGETARCH arg.
# So `--platform linux/arm64` yields a native arm64 image (no qemu, no pyarrow
# segfault on Apple Silicon) and `linux/amd64` stays byte-identical to CI — from one
# Dockerfile. Regenerate the index digests with scripts/resolve-base-digests.sh.

# docker-library/python revision 3362634339580d3232e65a66dd5a36c47ae7ff14,
# python 3.12.13-slim-bookworm. Pinned to the MULTI-ARCH INDEX digest (not a
# single-arch image digest) so --platform selects the native sub-image.
FROM docker.io/library/python@sha256:8a7e7cc04fd3e2bd787f7f24e22d5d119aa590d429b50c95dfe12b3abe52f48b

LABEL org.opencontainers.image.base.revision="3362634339580d3232e65a66dd5a36c47ae7ff14" \
      org.opencontainers.image.uv.revision="0e961dd9a2bb6f73493d9e8398b725ad2d3b3837"

RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      curl \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# jj (Jujutsu) — required so the real-jj parting e2e (tests/integration/
# test_part_e2e.py) actually runs in CI instead of silently skipping. Arch-templated:
# TARGETARCH is set automatically by the builder from --platform (amd64|arm64); the
# matching musl tarball is downloaded and checksum-verified. Both checksums pinned.
ARG TARGETARCH
ARG JJ_VERSION=0.42.0
ARG JJ_SHA256_AMD64=2d91e81d649e617a81608e7401ad1106029c15ece01ac928c4a351abef42be6a
ARG JJ_SHA256_ARM64=bc962ac57ec264541a62ed8492f080898380a277222b115e1ed96163196e6fc8
RUN set -eu; \
    case "${TARGETARCH:-amd64}" in \
      amd64) jj_arch=x86_64;  jj_sha="${JJ_SHA256_AMD64}" ;; \
      arm64) jj_arch=aarch64; jj_sha="${JJ_SHA256_ARM64}" ;; \
      *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -sSfL -o /tmp/jj.tgz \
      "https://github.com/jj-vcs/jj/releases/download/v${JJ_VERSION}/jj-v${JJ_VERSION}-${jj_arch}-unknown-linux-musl.tar.gz"; \
    echo "${jj_sha}  /tmp/jj.tgz" | sha256sum -c -; \
    tar -xzf /tmp/jj.tgz -C /usr/local/bin --strip-components=1 ./jj; \
    rm /tmp/jj.tgz; \
    jj --version

# Venv lives outside /workspace so the host's ro mount can't shadow it.
ENV UV_PROJECT_ENVIRONMENT=/opt/test-venv \
    VIRTUAL_ENV=/opt/test-venv \
    UV_NO_PROGRESS=1

COPY --from=ghcr.io/astral-sh/uv@sha256:3b7b60a81d3c57ef471703e5c83fd4aaa33abcd403596fb22ab07db85ae91347 /uv /usr/local/bin/uv

WORKDIR /workspace

COPY pyproject.toml uv.lock LICENSE README.md ./
RUN --security=insecure uv sync --frozen --group dev --no-install-project

COPY . .

RUN --security=insecure uv sync --frozen --group dev

# Extra deps for integration tests (mypy for type-check plugin, pyarrow for parquet pipeline)
RUN --security=insecure uv pip install mypy==1.15.0 pyarrow==24.0.0

RUN groupadd -r caliper \
    && useradd -r -g caliper -m -d /home/caliper -s /bin/sh caliper \
    && chown -R caliper:caliper /workspace /home/caliper /opt/test-venv

ENV CALIPER_ALLOW_GLOBAL=1 \
    XDG_CACHE_HOME=/home/caliper/.cache

USER caliper

ENTRYPOINT ["uv", "run"]
